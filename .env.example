# Web3Forms access key for the contact form (static POST, no backend).
# Get a free key at https://web3forms.com → paste below, then copy this file to `.env`.
# Exposed to the client (Astro PUBLIC_ prefix) — that's expected for Web3Forms.
PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key

# Base path override. Leave unset for GitHub Pages (base = /tcmt_web).
# For the custom domain tcmtech.co.th, set SITE_BASE=/ and add public/CNAME.
# SITE_BASE=/
