---
// English project detail page — served at /en/projects/[slug]
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import CtaBanner from '../../../components/CtaBanner.astro';
import { t, localizePath, type Lang } from '../../../i18n/ui';
import { filterByLocale, entrySlug } from '../../../lib/content';

export async function getStaticPaths() {
  const lang = 'en' as const;
  const allProjects = await getCollection('projects');
  const projects = filterByLocale(allProjects, lang);
  return projects.map((project) => ({
    params: { slug: entrySlug(project) },
    props: { project, lang },
  }));
}

const { project, lang } = Astro.props as {
  project: Awaited<ReturnType<typeof getCollection<'projects'>>>[number];
  lang: Lang;
};

const sectorLabel: Record<string, string> = {
  gov: t(lang, 'projects.filter.gov'),
  edu: t(lang, 'projects.filter.edu'),
  private: t(lang, 'projects.filter.private'),
};

const slug = entrySlug(project);
const { Content } = await render(project);
---

<BaseLayout
  lang={lang}
  path={`/projects/${slug}`}
  title={project.data.title}
  description={project.data.summary}
>
  <!-- Page hero -->
  <section class="bg-brand-900 pb-16 pt-24 sm:pt-28">
    <div class="container-tcm">
      <nav class="mb-6 flex flex-wrap items-center gap-2 text-sm text-brand-300" aria-label="breadcrumb">
        <a href={localizePath('/', lang)} class="hover:text-white transition-colors">{t(lang, 'nav.home')}</a>
        <span aria-hidden="true">›</span>
        <a href={localizePath('/projects', lang)} class="hover:text-white transition-colors">{t(lang, 'nav.projects')}</a>
        <span aria-hidden="true">›</span>
        <span class="text-white" aria-current="page">{project.data.client}</span>
      </nav>

      <span class="mb-4 inline-flex rounded-full bg-brand-600/40 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-brand-300">
        {sectorLabel[project.data.sector]}
      </span>

      <h1 class="mt-2 max-w-3xl text-4xl font-bold text-white sm:text-5xl leading-tight">
        {project.data.title}
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-brand-300">
        {project.data.summary}
      </p>
      <div class="mt-8">
        <Button href={localizePath('/contact', lang)} variant="white" size="md">
          {t(lang, 'btn.contactSales')}
        </Button>
      </div>
    </div>
  </section>

  <!-- Meta strip -->
  <section class="border-b border-slate-100 bg-white py-8">
    <div class="container-tcm">
      <dl class="flex flex-wrap gap-x-10 gap-y-4 text-sm">
        <div>
          <dt class="font-semibold text-ink">{t(lang, 'projects.client')}</dt>
          <dd class="mt-1 text-muted">{project.data.client}</dd>
        </div>
        <div>
          <dt class="font-semibold text-ink">{t(lang, 'projects.year')}</dt>
          <dd class="mt-1 text-muted">{project.data.year}</dd>
        </div>
        <div>
          <dt class="font-semibold text-ink">{t(lang, 'projects.sector')}</dt>
          <dd class="mt-1 text-muted">{sectorLabel[project.data.sector]}</dd>
        </div>
        {project.data.tags.length > 0 && (
          <div>
            <dt class="font-semibold text-ink">Tags</dt>
            <dd class="mt-1 flex flex-wrap gap-2">
              {project.data.tags.map((tag) => (
                <span class="rounded-full bg-slate-100 px-3 py-0.5 text-xs text-slate-600">{tag}</span>
              ))}
            </dd>
          </div>
        )}
      </dl>
    </div>
  </section>

  <!-- Main body -->
  <section class="section">
    <div class="container-tcm">
      <div class="mx-auto max-w-3xl">
        {/* T3 — Scope / services delivered (credible case-study framing, no metrics) */}
        {project.data.services.length > 0 && (
          <div class="mb-10 rounded-2xl bg-bg-soft p-7 ring-1 ring-slate-100 sm:p-8" style="background-color: var(--bg-soft);">
            <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-brand-600">
              {t(lang, 'projects.services')}
            </h2>
            <ul class="mt-5 grid gap-x-8 gap-y-3 sm:grid-cols-2">
              {project.data.services.map((svc) => (
                <li class="flex items-start gap-3">
                  <span
                    class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-accent-gradient-soft text-white"
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="h-3.5 w-3.5"
                    >
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                  </span>
                  <span class="text-sm leading-relaxed text-ink">{svc}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="project-content">
          <Content />
        </div>

        <div class="mt-12 flex flex-wrap gap-4">
          <Button href={localizePath('/projects', lang)} variant="secondary">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-4 w-4"
              aria-hidden="true"
            >
              <path d="M19 12H5M11 18l-6-6 6-6" />
            </svg>
            {t(lang, 'nav.projects')}
          </Button>
          <Button href={localizePath('/contact', lang)} variant="primary">
            {t(lang, 'btn.contactUs')}
          </Button>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner lang={lang} />
</BaseLayout>

<style>
  .project-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .project-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    color: #0f172a;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .project-content :global(p) {
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .project-content :global(ul) {
    margin: 1rem 0 1rem 1.5rem;
    list-style-type: disc;
  }
  .project-content :global(ol) {
    margin: 1rem 0 1rem 1.5rem;
    list-style-type: decimal;
  }
  .project-content :global(li) {
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 0.375rem;
  }
  .project-content :global(blockquote) {
    border-left: 4px solid #2f80ed;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--muted);
    font-style: italic;
  }
  .project-content :global(strong) {
    font-weight: 600;
    color: #0f172a;
  }
  .project-content :global(a) {
    color: #1565d8;
  }
  .project-content :global(a:hover) {
    text-decoration: underline;
  }
</style>
