---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t, localizePath } from '../../../i18n/ui';
import { services as serviceMeta } from '../../../data/site';
import { filterByLocale, entrySlug } from '../../../lib/content';
import SectionTitle from '../../../components/SectionTitle.astro';
import Button from '../../../components/Button.astro';
import CtaBanner from '../../../components/CtaBanner.astro';
import ServiceCard from '../../../components/ServiceCard.astro';

export async function getStaticPaths() {
  const lang = 'en' as const;
  const all = await getCollection('services');
  const entries = filterByLocale(all, lang);
  return entries.map((entry) => ({
    params: { slug: entrySlug(entry) },
    props: { entry },
  }));
}

const lang = 'en' as const;
const { entry } = Astro.props;
const { Content } = await render(entry);
const slug = entrySlug(entry);

// Related services (exclude current)
const related = serviceMeta.filter((s) => s.slug !== slug).slice(0, 3);
---

<BaseLayout
  lang={lang}
  path={`/services/${slug}`}
  title={entry.data.title}
  description={entry.data.summary}
>
  <!-- Page Hero — LIGHT: soft-blue bg, blue eyebrow, navy h1 -->
  <section class="border-b border-line bg-bg-soft pb-16 pt-24 sm:pt-28">
    <div class="container-tcm">
      <!-- Breadcrumb — contrast-safe: muted (#51607a) on white, 6.4:1 -->
      <nav class="mb-6 flex flex-wrap items-center gap-2 text-sm text-muted" aria-label="Breadcrumb">
        <a href={localizePath('/', lang)} class="transition-colors hover:text-brand-600">
          {t(lang, 'nav.home')}
        </a>
        <span aria-hidden="true" class="text-line">›</span>
        <a href={localizePath('/services', lang)} class="transition-colors hover:text-brand-600">
          {t(lang, 'nav.services')}
        </a>
        <span aria-hidden="true" class="text-line">›</span>
        <span class="text-ink">{entry.data.title}</span>
      </nav>

      <!-- Eyebrow -->
      <p class="eyebrow mb-4">
        <span class="inline-block h-1 w-5 rounded-full bg-brand-600" aria-hidden="true"></span>
        {t(lang, 'nav.services')}
      </p>

      <h1 class="max-w-3xl text-4xl font-bold tracking-tight text-ink sm:text-5xl">
        {entry.data.title}
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">
        {entry.data.summary}
      </p>
      <div class="mt-8">
        <Button href={localizePath('/contact', lang)} variant="primary" size="md">
          {t(lang, 'btn.getQuote')}
        </Button>
      </div>
    </div>
  </section>

  <!-- Content body -->
  <section class="section bg-white">
    <div class="container-tcm">
      <div class="mx-auto max-w-3xl">
        <div class="service-content">
          <Content />
        </div>
      </div>
    </div>
  </section>

  <!-- Related services — warm cream bg -->
  {related.length > 0 && (
    <section class="section bg-bg-cream">
      <div class="container-tcm">
        <SectionTitle
          eyebrow="What we do"
          title={t(lang, 'nav.services')}
          subtitle={t(lang, 'services.subtitle')}
        />
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((s) => (
            <ServiceCard
              slug={s.slug}
              title={s.title[lang]}
              summary={s.summary[lang]}
              icon={s.icon}
              href={localizePath(`/services/${s.slug}`, lang)}
            />
          ))}
        </div>
        <div class="mt-10 text-center">
          <Button href={localizePath('/services', lang)} variant="secondary" size="md">
            {t(lang, 'btn.viewServices')}
          </Button>
        </div>
      </div>
    </section>
  )}

  <CtaBanner lang={lang} />
</BaseLayout>

<style is:global>
  /* Service body content typography — navy headings, AA-safe muted body */
  .service-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--ink);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .service-content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--ink);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .service-content p {
    margin-bottom: 1rem;
    color: var(--muted);
    line-height: 1.75;
  }
  .service-content ul,
  .service-content ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .service-content li {
    margin-bottom: 0.5rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .service-content ul > li {
    list-style-type: disc;
  }
  .service-content ol > li {
    list-style-type: decimal;
  }
  .service-content strong {
    font-weight: 600;
    color: var(--ink);
  }
  .service-content a {
    color: var(--brand-600);
    text-decoration: underline;
  }
  .service-content a:hover {
    color: var(--brand-700);
  }
</style>
