---
// Thai project detail page — served at /projects/[slug]
// DESIGN V4 (TANGERINE-STYLE) — light page hero, flat meta strip, flat services panel.
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { t, localizePath, type Lang } from '../../i18n/ui';
import { filterByLocale, entrySlug } from '../../lib/content';

export async function getStaticPaths() {
  const lang = 'th' as const;
  const allProjects = await getCollection('projects');
  const projects = filterByLocale(allProjects, lang);
  return projects.map((project) => ({
    params: { slug: entrySlug(project) },
    props: { project, lang },
  }));
}

const { project, lang } = Astro.props as {
  project: Awaited<ReturnType<typeof getCollection<'projects'>>>[number];
  lang: Lang;
};

const sectorLabel: Record<string, string> = {
  gov:     t(lang, 'projects.filter.gov'),
  edu:     t(lang, 'projects.filter.edu'),
  private: t(lang, 'projects.filter.private'),
};

const slug = entrySlug(project);
const { Content } = await render(project);
---

<BaseLayout
  lang={lang}
  path={`/projects/${slug}`}
  title={project.data.title}
  description={project.data.summary}
>
  <!-- Page hero — LIGHT soft-blue bg (was dark brand-900) -->
  <section class="pb-16 pt-24 sm:pt-28" style="background-color: var(--bg-soft);">
    <div class="container-tcm">
      <!-- Breadcrumb — navy ink on soft bg (AA-safe) -->
      <nav class="mb-6 flex flex-wrap items-center gap-2 text-sm text-muted" aria-label="breadcrumb">
        <a href={localizePath('/', lang)} class="hover:text-brand-700 transition-colors">{t(lang, 'nav.home')}</a>
        <span aria-hidden="true" class="text-line">›</span>
        <a href={localizePath('/projects', lang)} class="hover:text-brand-700 transition-colors">{t(lang, 'nav.projects')}</a>
        <span aria-hidden="true" class="text-line">›</span>
        <span class="text-ink font-medium" aria-current="page">{project.data.client}</span>
      </nav>

      <!-- Sector pill -->
      <span class="pill-soft mb-4 inline-flex">
        <span class="h-1.5 w-1.5 rounded-full bg-brand-600" aria-hidden="true"></span>
        {sectorLabel[project.data.sector]}
      </span>

      <h1 class="mt-3 max-w-3xl text-4xl font-bold text-ink sm:text-5xl leading-tight">
        {project.data.title}
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-muted">
        {project.data.summary}
      </p>
      <div class="mt-8">
        <Button href={localizePath('/contact', lang)} variant="primary" size="md">
          {t(lang, 'btn.contactSales')}
        </Button>
      </div>
    </div>
  </section>

  <!-- Meta strip — white bg with hairline bottom border -->
  <section class="border-b border-line bg-white py-8">
    <div class="container-tcm">
      <dl class="flex flex-wrap gap-x-10 gap-y-4 text-sm">
        <div>
          <dt class="font-semibold text-ink">{t(lang, 'projects.client')}</dt>
          <dd class="mt-1 text-muted">{project.data.client}</dd>
        </div>
        <div>
          <dt class="font-semibold text-ink">{t(lang, 'projects.year')}</dt>
          <dd class="mt-1 text-muted">{project.data.year}</dd>
        </div>
        <div>
          <dt class="font-semibold text-ink">{t(lang, 'projects.sector')}</dt>
          <dd class="mt-1 text-muted">{sectorLabel[project.data.sector]}</dd>
        </div>
        {project.data.tags.length > 0 && (
          <div>
            <dt class="font-semibold text-ink">Tags</dt>
            <dd class="mt-1 flex flex-wrap gap-2">
              {project.data.tags.map((tag) => (
                <span class="rounded-full bg-brand-50 px-3 py-0.5 text-xs text-brand-700 ring-1 ring-inset ring-brand-100">{tag}</span>
              ))}
            </dd>
          </div>
        )}
      </dl>
    </div>
  </section>

  <!-- Main body — white bg -->
  <section class="section bg-white">
    <div class="container-tcm">
      <div class="mx-auto max-w-3xl">
        {/* Scope / services delivered — flat soft-blue panel */}
        {project.data.services.length > 0 && (
          <div class="mb-10 rounded-2xl border border-line p-7 sm:p-8" style="background-color: var(--bg-soft);">
            <p class="eyebrow mb-4">
              <span class="inline-block h-1 w-5 rounded-full bg-brand-600" aria-hidden="true"></span>
              {t(lang, 'projects.services')}
            </p>
            <ul class="grid gap-x-8 gap-y-3 sm:grid-cols-2">
              {project.data.services.map((svc) => (
                <li class="flex items-start gap-3">
                  <span
                    class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-brand-600 text-white"
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="h-3.5 w-3.5"
                    >
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                  </span>
                  <span class="text-sm leading-relaxed text-ink">{svc}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="project-content">
          <Content />
        </div>

        <div class="mt-12 flex flex-wrap gap-4">
          <Button href={localizePath('/projects', lang)} variant="secondary">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-4 w-4"
              aria-hidden="true"
            >
              <path d="M19 12H5M11 18l-6-6 6-6" />
            </svg>
            {t(lang, 'nav.projects')}
          </Button>
          <Button href={localizePath('/contact', lang)} variant="primary">
            {t(lang, 'btn.contactUs')}
          </Button>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner lang={lang} />
</BaseLayout>

<style>
  /* Project body content typography — light system colors */
  .project-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--ink);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .project-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--ink);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .project-content :global(p) {
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .project-content :global(ul) {
    margin: 1rem 0 1rem 1.5rem;
    list-style-type: disc;
  }
  .project-content :global(ol) {
    margin: 1rem 0 1rem 1.5rem;
    list-style-type: decimal;
  }
  .project-content :global(li) {
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 0.375rem;
  }
  .project-content :global(blockquote) {
    border-left: 4px solid #1565d8;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--muted);
    font-style: italic;
  }
  .project-content :global(strong) {
    font-weight: 600;
    color: var(--ink);
  }
  .project-content :global(a) {
    color: #1565d8;
  }
  .project-content :global(a:hover) {
    text-decoration: underline;
  }
</style>
