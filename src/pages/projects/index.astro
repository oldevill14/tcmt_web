---
// Thai projects list page — served at /projects
// DESIGN V4 (TANGERINE-STYLE) — light page header + cream bg, flat cards, pill tabs.
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { t, localizePath, type Lang } from '../../i18n/ui';
import { filterByLocale, entrySlug } from '../../lib/content';

const lang = 'th' as const;

const allProjects = await getCollection('projects');
const projects = filterByLocale(allProjects, lang);

const sectorLabels: Record<string, string> = {
  all:     t(lang, 'projects.filter.all'),
  gov:     t(lang, 'projects.filter.gov'),
  edu:     t(lang, 'projects.filter.edu'),
  private: t(lang, 'projects.filter.private'),
};
---

<BaseLayout
  lang={lang}
  path="/projects"
  title={t(lang, 'projects.title')}
  description={t(lang, 'projects.subtitle')}
>
  <!-- Page header — LIGHT (was dark bg-brand-900) -->
  <section class="py-20 sm:py-24" style="background-color: var(--bg-soft);">
    <div class="container-tcm">
      <SectionTitle
        as="h1"
        eyebrow={t(lang, 'nav.projects')}
        title={t(lang, 'projects.title')}
        subtitle={t(lang, 'projects.subtitle')}
      />
    </div>
  </section>

  <!-- Filter tabs + grid — white bg -->
  <section class="section bg-white">
    <div class="container-tcm">
      <!-- Sector filter: Tangerine-style rounded-full pill tabs -->
      <div
        class="mb-10 flex flex-wrap justify-center gap-3"
        role="tablist"
        aria-label={t(lang, 'projects.filter.all')}
      >
        {Object.entries(sectorLabels).map(([key, label]) => (
          <button
            type="button"
            role="tab"
            aria-selected={key === 'all' ? 'true' : 'false'}
            data-sector={key}
            class:list={[
              'sector-tab',
              'inline-flex min-h-[44px] cursor-pointer items-center rounded-full px-5 py-2.5 text-sm font-semibold transition-all duration-200',
              'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2',
              key === 'all'
                ? 'bg-brand-600 text-white shadow-pill'
                : 'pill-outline',
            ]}
          >
            {label}
          </button>
        ))}
      </div>

      {projects.length === 0 ? (
        <p class="py-16 text-center text-muted">{t(lang, 'projects.empty')}</p>
      ) : (
        <div id="projects-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {projects.map((project) => {
            const slug = entrySlug(project);
            return (
              <article data-sector={project.data.sector} class="project-card">
                <!-- Flat light card — hairline border, soft shadow, hover-lift -->
                <a
                  href={localizePath(`/projects/${slug}`, lang)}
                  class="group block h-full rounded-2xl border border-line bg-white p-6 shadow-card transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover hover:border-brand-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 cursor-pointer"
                  aria-label={project.data.title}
                >
                  <div class="flex flex-col gap-3 h-full">
                    <!-- Sector chip + case-study marker -->
                    <div class="flex flex-wrap items-center gap-2">
                      <span class="pill-soft">
                        <span class="h-1.5 w-1.5 rounded-full bg-brand-600" aria-hidden="true"></span>
                        {sectorLabels[project.data.sector]}
                      </span>
                      <span class="text-[0.7rem] font-medium uppercase tracking-[0.14em] text-muted">
                        {t(lang, 'projects.caseStudy')}
                      </span>
                    </div>

                    <h2 class="text-lg font-bold text-ink leading-snug group-hover:text-brand-700 transition-colors duration-200">
                      {project.data.title}
                    </h2>
                    <p class="text-sm text-muted line-clamp-3 leading-relaxed">
                      {project.data.summary}
                    </p>

                    {/* Services scope chips */}
                    {project.data.services.length > 0 && (
                      <div class="flex flex-wrap gap-1.5">
                        {project.data.services.slice(0, 3).map((svc) => (
                          <span class="rounded-full bg-brand-50 px-2.5 py-0.5 text-[0.72rem] font-medium text-brand-700 ring-1 ring-inset ring-brand-100">
                            {svc}
                          </span>
                        ))}
                        {project.data.services.length > 3 && (
                          <span class="rounded-full px-1.5 py-0.5 text-[0.72rem] font-semibold text-brand-600">
                            +{project.data.services.length - 3}
                          </span>
                        )}
                      </div>
                    )}

                    <dl class="mt-auto flex flex-wrap gap-x-6 gap-y-1 text-sm text-muted border-t border-line pt-4">
                      <div>
                        <dt class="inline font-semibold text-ink">{t(lang, 'projects.client')}: </dt>
                        <dd class="inline">{project.data.client}</dd>
                      </div>
                      <div>
                        <dt class="inline font-semibold text-ink">{t(lang, 'projects.year')}: </dt>
                        <dd class="inline">{project.data.year}</dd>
                      </div>
                    </dl>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <CtaBanner lang={lang} />
</BaseLayout>

<script>
  // Sector filter — pure JS, no framework needed.
  const tabs = document.querySelectorAll<HTMLElement>('.sector-tab');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const sector = tab.dataset.sector ?? 'all';

      // Update tab styles + ARIA state
      tabs.forEach((t) => {
        const isActive = t.dataset.sector === sector;
        t.setAttribute('aria-selected', isActive ? 'true' : 'false');

        // Active = solid blue pill; inactive = outline pill
        if (isActive) {
          t.classList.add('bg-brand-600', 'text-white', 'shadow-pill');
          t.classList.remove('bg-white', 'text-ink', 'ring-1', 'ring-inset', 'ring-line', 'shadow-sm',
            'hover:ring-brand-300', 'hover:text-brand-700');
        } else {
          t.classList.remove('bg-brand-600', 'text-white', 'shadow-pill');
          t.classList.add('bg-white', 'text-ink', 'ring-1', 'ring-inset', 'ring-line', 'shadow-sm',
            'hover:ring-brand-300', 'hover:text-brand-700');
        }
      });

      // Show/hide cards
      cards.forEach((card) => {
        const cardSector = card.dataset.sector ?? '';
        const visible = sector === 'all' || cardSector === sector;
        card.style.display = visible ? '' : 'none';
      });
    });
  });
</script>
