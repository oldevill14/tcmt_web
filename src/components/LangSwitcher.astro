---
// Toggles th <-> en while preserving the current path. Pure link, no JS.
import { switchLangPath, localizePath, t, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  class?: string;
  /** On routes with no localized sibling (e.g. 404), link to the other locale's home instead. */
  toHome?: boolean;
}

const { lang, class: className = '', toHome = false } = Astro.props;
const target: Lang = lang === 'th' ? 'en' : 'th';
const href = toHome ? localizePath('/', target) : switchLangPath(Astro.url, target);
---

<a
  href={href}
  hreflang={target}
  aria-label={t(lang, 'a11y.langSwitch')}
  class:list={[
    'inline-flex min-h-[44px] cursor-pointer items-center gap-1.5 rounded-full px-3.5 py-2 text-sm font-semibold text-ink ring-1 ring-slate-200 transition hover:bg-slate-50 hover:text-brand-700',
    className,
  ]}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    class="h-4 w-4"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="9"></circle>
    <path d="M3 12h18M12 3c2.5 2.5 3.8 5.7 3.8 9S14.5 18.5 12 21"></path>
    <path d="M12 3c-2.5 2.5-3.8 5.7-3.8 9S9.5 18.5 12 21"></path>
  </svg>
  {t(lang, 'lang.other')}
</a>
