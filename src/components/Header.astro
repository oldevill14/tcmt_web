---
// Sticky header: TCM TECHNOLOGY wordmark + nav (from ui.ts) + LangSwitcher.
// Mobile: a CSS-only disclosure menu (checkbox hack, no JS).
import { t, localizePath, type Lang } from '../i18n/ui';
import { site } from '../data/site';
import LangSwitcher from './LangSwitcher.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const nav: { key: Parameters<typeof t>[1]; path: string }[] = [
  { key: 'nav.home', path: '/' },
  { key: 'nav.about', path: '/about' },
  { key: 'nav.services', path: '/services' },
  { key: 'nav.projects', path: '/projects' },
  { key: 'nav.clients', path: '/clients' },
  { key: 'nav.contact', path: '/contact' },
];

const currentPath = Astro.url.pathname;
function isActive(path: string): boolean {
  const target = localizePath(path, lang);
  if (path === '/') return currentPath === target || currentPath === `${target}/`;
  return currentPath.startsWith(target);
}
---

<header
  class="sticky top-0 z-50 border-b border-slate-100 bg-white/90 backdrop-blur supports-[backdrop-filter]:bg-white/75"
>
  <div class="container-tcm flex h-16 items-center justify-between gap-4">
    <a
      href={localizePath('/', lang)}
      class="flex items-center gap-2 font-bold tracking-tight text-brand-900"
    >
      <span
        class="grid h-8 w-8 place-items-center rounded-lg bg-brand-gradient text-sm font-extrabold text-white"
        aria-hidden="true">T</span
      >
      <span class="text-base sm:text-lg">{site.wordmark}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={localizePath(item.path, lang)}
            aria-current={isActive(item.path) ? 'page' : undefined}
            class:list={[
              'rounded-full px-3 py-2 text-sm font-medium transition',
              isActive(item.path)
                ? 'text-brand-700'
                : 'text-ink hover:text-brand-700',
            ]}
          >
            {t(lang, item.key)}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <LangSwitcher lang={lang} />
    </div>

    <!-- Mobile: checkbox-hack disclosure -->
    <input id="nav-toggle" type="checkbox" class="peer hidden" aria-hidden="true" />
    <label
      for="nav-toggle"
      class="grid h-10 w-10 cursor-pointer place-items-center rounded-lg text-ink ring-1 ring-slate-200 lg:hidden"
      aria-label={t(lang, 'a11y.openMenu')}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        class="h-5 w-5"
        aria-hidden="true"
      >
        <path d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </label>

    <div
      class="absolute inset-x-0 top-16 hidden border-b border-slate-100 bg-white shadow-sm peer-checked:block lg:!hidden"
    >
      <nav class="container-tcm flex flex-col py-3" aria-label="Mobile">
        {
          nav.map((item) => (
            <a
              href={localizePath(item.path, lang)}
              aria-current={isActive(item.path) ? 'page' : undefined}
              class:list={[
                'rounded-lg px-3 py-3 text-base font-medium transition',
                isActive(item.path)
                  ? 'bg-slate-50 text-brand-700'
                  : 'text-ink hover:bg-slate-50',
              ]}
            >
              {t(lang, item.key)}
            </a>
          ))
        }
        <div class="px-3 py-3">
          <LangSwitcher lang={lang} />
        </div>
      </nav>
    </div>
  </div>
</header>
