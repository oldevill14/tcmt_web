---
// Sticky glassy header: real TCM logo SVG + nav (from ui.ts) + LangSwitcher.
// Mobile: a CSS-only disclosure menu (checkbox hack, no JS).
import { t, localizePath, withBase, type Lang } from '../i18n/ui';
import { site } from '../data/site';
import LangSwitcher from './LangSwitcher.astro';
import Button from './Button.astro';

interface Props {
  lang: Lang;
  /** Pass-through: make the language toggle link to the other locale's home (used on 404). */
  langSwitchHome?: boolean;
}
const { lang, langSwitchHome = false } = Astro.props;

const nav: { key: Parameters<typeof t>[1]; path: string }[] = [
  { key: 'nav.home', path: '/' },
  { key: 'nav.about', path: '/about' },
  { key: 'nav.services', path: '/services' },
  { key: 'nav.projects', path: '/projects' },
  { key: 'nav.clients', path: '/clients' },
  { key: 'nav.contact', path: '/contact' },
];

const currentPath = Astro.url.pathname;
function isActive(path: string): boolean {
  const target = localizePath(path, lang);
  if (path === '/') return currentPath === target || currentPath === `${target}/`;
  return currentPath.startsWith(target);
}

const logoSrc = withBase('/logo-tcm.svg');
---

<header
  class="sticky top-0 z-50 border-b border-line bg-white/90 backdrop-blur-xl supports-[backdrop-filter]:bg-white/80"
>
  <div class="container-tcm flex h-16 items-center justify-between gap-4">
    <a
      href={localizePath('/', lang)}
      class="group flex items-center"
      aria-label={site.wordmark}
    >
      <img
        src={logoSrc}
        alt={site.wordmark}
        width="148"
        height="42"
        class="h-9 w-auto transition-transform duration-300 group-hover:scale-[1.03] sm:h-10"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={localizePath(item.path, lang)}
            aria-current={isActive(item.path) ? 'page' : undefined}
            class:list={[
              'relative inline-flex min-h-[44px] cursor-pointer items-center rounded-full px-4 py-2 text-sm font-semibold transition-colors',
              isActive(item.path)
                ? 'bg-brand-50 text-brand-700'
                : 'text-ink/75 hover:bg-bg-soft hover:text-brand-700',
            ]}
          >
            {t(lang, item.key)}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <LangSwitcher lang={lang} toHome={langSwitchHome} />
      <!-- T4 — Contact Sales is the PRIMARY conversion (header) — blue pill -->
      <Button href={localizePath('/contact', lang)} variant="primary" size="sm">
        {t(lang, 'btn.contactSales')}
      </Button>
    </div>

    <!-- Mobile: checkbox-hack disclosure -->
    <input id="nav-toggle" type="checkbox" class="peer hidden" aria-hidden="true" />
    <label
      for="nav-toggle"
      class="grid h-11 w-11 cursor-pointer place-items-center rounded-full text-ink ring-1 ring-line transition hover:ring-brand-300 hover:text-brand-700 lg:hidden"
      aria-label={t(lang, 'a11y.openMenu')}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        class="h-5 w-5"
        aria-hidden="true"
      >
        <path d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </label>

    <div
      class="absolute inset-x-0 top-16 hidden border-b border-line bg-white/98 shadow-card backdrop-blur-xl peer-checked:block lg:!hidden"
    >
      <nav class="container-tcm flex flex-col py-3" aria-label="Mobile">
        {
          nav.map((item) => (
            <a
              href={localizePath(item.path, lang)}
              aria-current={isActive(item.path) ? 'page' : undefined}
              class:list={[
                'rounded-xl px-3 py-3 text-base font-semibold transition',
                isActive(item.path)
                  ? 'bg-brand-50 text-brand-700'
                  : 'text-ink hover:bg-bg-soft',
              ]}
            >
              {t(lang, item.key)}
            </a>
          ))
        }
        <!-- T4 — Contact Sales primary CTA (mobile) -->
        <div class="px-3 pt-2">
          <Button
            href={localizePath('/contact', lang)}
            variant="primary"
            size="md"
            class="w-full"
          >
            {t(lang, 'btn.contactSales')}
          </Button>
        </div>
        <div class="px-3 py-3">
          <LangSwitcher lang={lang} toHome={langSwitchHome} />
        </div>
      </nav>
    </div>
  </div>
</header>
