---
// Sticky glassy header: real TCM logo SVG + nav (from ui.ts) + LangSwitcher.
// Mobile: a CSS-only disclosure menu (checkbox hack, no JS).
import { t, localizePath, withBase, type Lang } from '../i18n/ui';
import { site } from '../data/site';
import LangSwitcher from './LangSwitcher.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const nav: { key: Parameters<typeof t>[1]; path: string }[] = [
  { key: 'nav.home', path: '/' },
  { key: 'nav.about', path: '/about' },
  { key: 'nav.services', path: '/services' },
  { key: 'nav.projects', path: '/projects' },
  { key: 'nav.clients', path: '/clients' },
  { key: 'nav.contact', path: '/contact' },
];

const currentPath = Astro.url.pathname;
function isActive(path: string): boolean {
  const target = localizePath(path, lang);
  if (path === '/') return currentPath === target || currentPath === `${target}/`;
  return currentPath.startsWith(target);
}

const logoSrc = withBase('/logo-tcm.svg');
---

<header
  class="sticky top-0 z-50 border-b border-slate-200/60 bg-white/80 backdrop-blur-xl supports-[backdrop-filter]:bg-white/65"
>
  <!-- hairline accent gradient on the bottom edge -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-accent-cyan/50 to-transparent"
    aria-hidden="true"
  >
  </div>

  <div class="container-tcm flex h-16 items-center justify-between gap-4">
    <a
      href={localizePath('/', lang)}
      class="group flex items-center"
      aria-label={site.wordmark}
    >
      <img
        src={logoSrc}
        alt={site.wordmark}
        width="148"
        height="42"
        class="h-9 w-auto transition-transform duration-300 group-hover:scale-[1.03] sm:h-10"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={localizePath(item.path, lang)}
            aria-current={isActive(item.path) ? 'page' : undefined}
            class:list={[
              'relative rounded-full px-3.5 py-2 text-sm font-medium transition-colors',
              isActive(item.path)
                ? 'text-brand-700'
                : 'text-ink/80 hover:text-brand-700',
            ]}
          >
            {t(lang, item.key)}
            <span
              class:list={[
                'pointer-events-none absolute inset-x-3.5 -bottom-px h-0.5 rounded-full bg-accent-gradient-soft transition-transform duration-300',
                isActive(item.path)
                  ? 'scale-x-100'
                  : 'scale-x-0',
              ]}
              aria-hidden="true"
            />
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <LangSwitcher lang={lang} />
    </div>

    <!-- Mobile: checkbox-hack disclosure -->
    <input id="nav-toggle" type="checkbox" class="peer hidden" aria-hidden="true" />
    <label
      for="nav-toggle"
      class="grid h-10 w-10 cursor-pointer place-items-center rounded-xl text-ink ring-1 ring-slate-200 transition hover:ring-brand-300 lg:hidden"
      aria-label={t(lang, 'a11y.openMenu')}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        class="h-5 w-5"
        aria-hidden="true"
      >
        <path d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </label>

    <div
      class="absolute inset-x-0 top-16 hidden border-b border-slate-200/70 bg-white/95 shadow-lg backdrop-blur-xl peer-checked:block lg:!hidden"
    >
      <nav class="container-tcm flex flex-col py-3" aria-label="Mobile">
        {
          nav.map((item) => (
            <a
              href={localizePath(item.path, lang)}
              aria-current={isActive(item.path) ? 'page' : undefined}
              class:list={[
                'rounded-xl px-3 py-3 text-base font-medium transition',
                isActive(item.path)
                  ? 'bg-brand-500/10 text-brand-700'
                  : 'text-ink hover:bg-slate-50',
              ]}
            >
              {t(lang, item.key)}
            </a>
          ))
        }
        <div class="px-3 py-3">
          <LangSwitcher lang={lang} />
        </div>
      </nav>
    </div>
  </div>
</header>
