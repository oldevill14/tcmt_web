---
// T1 — Trust & Authority credentials band (DESIGN V2 evolution).
// A strip of SVG-icon credential badges that seats directly under the hero/stats.
// Reuses v2 tokens: card-surface, hover-lift, accent-gradient, eyebrow, data-reveal.
// Claims are credible (founded year, gov-trusted, 24/7 support, full SI) — no
// invented certifications. SVG icons only (no emoji). Reduced-motion safe via v2 CSS.
import { t, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

type K = Parameters<typeof t>[1];
// Inline icon path data (Heroicons-style, 24x24, stroke). One coherent set.
const icons: Record<string, string> = {
  // award / established
  award:
    '<circle cx="12" cy="8" r="5" /><path d="M8.5 12.5 7 21l5-3 5 3-1.5-8.5" />',
  // shield-check / government trust
  shield: '<path d="M12 3 5 6v5c0 4.5 3 7.5 7 9 4-1.5 7-4.5 7-9V6l-7-3Z" /><path d="m9.5 12 1.8 1.8L15 10" />',
  // clock / 24-7 support
  clock: '<circle cx="12" cy="12" r="9" /><path d="M12 7.5V12l3 2" />',
  // layers / full system integrator
  layers: '<path d="m12 3 9 5-9 5-9-5 9-5Z" /><path d="m3 13 9 5 9-5" /><path d="m3 17 9 5 9-5" />',
};

const badges: { icon: keyof typeof icons; title: K; desc: K }[] = [
  { icon: 'award', title: 'home.trust.founded.title' as K, desc: 'home.trust.founded.desc' as K },
  { icon: 'shield', title: 'home.trust.gov.title' as K, desc: 'home.trust.gov.desc' as K },
  { icon: 'clock', title: 'home.trust.support.title' as K, desc: 'home.trust.support.desc' as K },
  { icon: 'layers', title: 'home.trust.si.title' as K, desc: 'home.trust.si.desc' as K },
];
---

<ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
  {
    badges.map((b, i) => (
      <li data-reveal data-reveal-delay={i * 90}>
        <div class="group hover-lift flex h-full items-center gap-4 rounded-2xl border border-slate-200/70 bg-white/90 px-5 py-4 shadow-card backdrop-blur-sm">
          <span
            class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-500/10 text-brand-600 transition-colors duration-300 group-hover:bg-accent-gradient-soft group-hover:text-white"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-6 w-6"
              set:html={icons[b.icon]}
            />
          </span>
          <div class="min-w-0">
            <p class="text-sm font-bold leading-tight text-ink">{t(lang, b.title)}</p>
            <p class="mt-0.5 text-xs leading-snug text-muted">{t(lang, b.desc)}</p>
          </div>
        </div>
      </li>
    ))
  }
</ul>
