---
// Generic surface card (DESIGN V4 — flat light). Wrap arbitrary content.
// variant: 'surface' (default flat white card, hairline border),
//          'glass' (flat white — kept name), 'gradient-border' (white + hairline),
//          'soft' (cream/soft-blue wash card), 'dark' (flat white — legacy alias).
interface Props {
  href?: string;
  class?: string;
  hover?: boolean;
  variant?: 'surface' | 'glass' | 'gradient-border' | 'soft' | 'dark';
  padded?: boolean;
}

const {
  href,
  class: className = '',
  hover = true,
  variant = 'surface',
  padded = true,
} = Astro.props;

const variants: Record<string, string> = {
  surface: 'border border-line bg-white shadow-card',
  glass: 'border border-line bg-white shadow-card',
  'gradient-border': 'border border-line bg-white shadow-card',
  soft: 'border border-line bg-bg-soft',
  dark: 'border border-line bg-white shadow-card',
};

const base = 'block rounded-2xl';
const pad = padded ? 'p-6' : '';
const hoverCls = hover ? 'hover-lift' : '';
const cls = [base, pad, variants[variant] ?? variants.surface, hoverCls, className].join(' ');
---

{
  href ? (
    <a href={href} class={`${cls} cursor-pointer`}>
      <slot />
    </a>
  ) : (
    <div class={cls}>
      <slot />
    </div>
  )
}
