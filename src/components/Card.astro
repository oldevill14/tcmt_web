---
// Generic surface card (DESIGN V2). Wrap arbitrary content. Optionally a link card.
// variant: 'surface' (default white card), 'glass' (frosted, over soft/dark bg),
//          'gradient-border' (white card with an accent gradient ring), 'dark' (over navy).
interface Props {
  href?: string;
  class?: string;
  hover?: boolean;
  variant?: 'surface' | 'glass' | 'gradient-border' | 'dark';
  padded?: boolean;
}

const {
  href,
  class: className = '',
  hover = true,
  variant = 'surface',
  padded = true,
} = Astro.props;

const variants: Record<string, string> = {
  surface: 'bg-white shadow-card ring-1 ring-slate-100',
  glass: 'glass',
  'gradient-border': 'gradient-border bg-white shadow-card',
  dark: 'glass-dark',
};

const base = 'block rounded-2xl';
const pad = padded ? 'p-6' : '';
const hoverCls = hover ? 'hover-lift' : '';
const cls = [base, pad, variants[variant] ?? variants.surface, hoverCls, className].join(' ');
---

{
  href ? (
    <a href={href} class={`${cls} cursor-pointer`}>
      <slot />
    </a>
  ) : (
    <div class={cls}>
      <slot />
    </div>
  )
}
