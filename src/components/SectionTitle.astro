---
// Section heading with optional eyebrow + subtitle. Used to introduce page sections.
interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
  align?: 'left' | 'center';
  invert?: boolean; // true on dark backgrounds
  as?: 'h1' | 'h2' | 'h3';
  class?: string;
}

const {
  title,
  subtitle,
  eyebrow,
  align = 'center',
  invert = false,
  as = 'h2',
  class: className = '',
} = Astro.props;

const Heading = as;
const alignCls = align === 'center' ? 'text-center mx-auto' : 'text-left';
const titleColor = invert ? 'text-white' : 'text-ink';
const subColor = invert ? 'text-brand-300' : 'text-muted';
---

<div class:list={['max-w-2xl', alignCls, className]}>
  {
    eyebrow && (
      <p class="mb-2 text-sm font-semibold uppercase tracking-wider text-brand-500">
        {eyebrow}
      </p>
    )
  }
  <Heading class:list={['text-3xl font-bold sm:text-4xl', titleColor]}>
    {title}
  </Heading>
  {subtitle && <p class:list={['mt-3 text-base sm:text-lg', subColor]}>{subtitle}</p>}
</div>
