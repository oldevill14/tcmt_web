---
// Section heading (DESIGN V4) — blue uppercase eyebrow kicker + navy title +
// optional subtitle. The eyebrow must be a DISTINCT kicker — never equal to the
// title (audited in HomeSections). On light bg the title is navy ink; the
// `gradient` flag now resolves to a flat navy->blue ink clip (no rainbow).
interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
  align?: 'left' | 'center';
  invert?: boolean; // true on the single dark navy band
  gradient?: boolean; // render the title with the (flat) gradient-text treatment
  as?: 'h1' | 'h2' | 'h3';
  class?: string;
}

const {
  title,
  subtitle,
  eyebrow,
  align = 'center',
  invert = false,
  gradient = false,
  as = 'h2',
  class: className = '',
} = Astro.props;

const Heading = as;
const alignCls = align === 'center' ? 'text-center mx-auto' : 'text-left';
const titleColor = invert
  ? 'text-white'
  : gradient
    ? 'gradient-text'
    : 'text-ink';
const subColor = invert ? 'text-brand-200' : 'text-muted';
const kickerCls = invert ? 'eyebrow-light' : 'eyebrow';
---

<div class:list={['max-w-2xl', alignCls, className]}>
  {
    eyebrow && (
      <p class:list={[kickerCls, 'mb-3', align === 'center' && 'justify-center']}>
        <span
          class:list={[
            'inline-block h-1 w-5 rounded-full',
            invert ? 'bg-brand-300' : 'bg-brand-600',
          ]}
          aria-hidden="true"
        />
        {eyebrow}
      </p>
    )
  }
  <Heading
    class:list={[
      'text-3xl font-bold tracking-tight sm:text-4xl lg:text-[2.75rem] lg:leading-[1.12]',
      titleColor,
    ]}
  >
    {title}
  </Heading>
  {
    subtitle && (
      <p class:list={['mt-4 text-base leading-relaxed sm:text-lg', subColor]}>
        {subtitle}
      </p>
    )
  }
</div>
