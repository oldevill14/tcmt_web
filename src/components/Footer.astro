---
// Footer: wordmark + tagline, nav columns, contact block, copyright.
// All copy via ui.ts / site data.
import { t, localizePath, type Lang } from '../i18n/ui';
import { site, copyrightLine, companyAddress } from '../data/site';
import { services } from '../data/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const nav: { key: Parameters<typeof t>[1]; path: string }[] = [
  { key: 'nav.about', path: '/about' },
  { key: 'nav.services', path: '/services' },
  { key: 'nav.projects', path: '/projects' },
  { key: 'nav.clients', path: '/clients' },
  { key: 'nav.contact', path: '/contact' },
];
---

<footer class="border-t border-slate-100 bg-brand-900 text-slate-300">
  <div class="container-tcm grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <!-- Brand -->
    <div class="lg:col-span-1">
      <div class="flex items-center gap-2 font-bold text-white">
        <span
          class="grid h-8 w-8 place-items-center rounded-lg bg-brand-gradient text-sm font-extrabold text-white"
          aria-hidden="true">T</span
        >
        <span>{site.wordmark}</span>
      </div>
      <p class="mt-3 max-w-xs text-sm leading-relaxed text-slate-400">
        {t(lang, 'footer.tagline')}
      </p>
      <p class="mt-4 text-sm font-medium text-brand-300">{site.slogan}</p>
    </div>

    <!-- Nav -->
    <nav aria-label="Footer navigation">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-white">
        {t(lang, 'footer.nav.title')}
      </h2>
      <ul class="mt-4 space-y-2 text-sm">
        {
          nav.map((item) => (
            <li>
              <a
                href={localizePath(item.path, lang)}
                class="text-slate-400 transition hover:text-white"
              >
                {t(lang, item.key)}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Services -->
    <nav aria-label="Services">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-white">
        {t(lang, 'footer.services.title')}
      </h2>
      <ul class="mt-4 space-y-2 text-sm">
        {
          services.slice(0, 5).map((s) => (
            <li>
              <a
                href={localizePath(`/services/${s.slug}`, lang)}
                class="text-slate-400 transition hover:text-white"
              >
                {s.title[lang]}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Contact -->
    <div>
      <h2 class="text-sm font-semibold uppercase tracking-wider text-white">
        {t(lang, 'footer.contact.title')}
      </h2>
      <address class="mt-4 space-y-2 text-sm not-italic text-slate-400">
        <p>{companyAddress(lang)}</p>
        <p>
          <a href={`tel:${site.phoneIntl}`} class="transition hover:text-white"
            >{site.phone}</a
          >
        </p>
        <p>
          <a href={`mailto:${site.email}`} class="transition hover:text-white"
            >{site.email}</a
          >
        </p>
      </address>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div
      class="container-tcm flex flex-col items-center justify-between gap-3 py-6 text-sm text-slate-400 sm:flex-row"
    >
      <p>{copyrightLine(lang)} · {t(lang, 'footer.rights')}</p>
      <a
        href={localizePath('/privacy-policy', lang)}
        class="transition hover:text-white"
      >
        {t(lang, 'footer.privacy')}
      </a>
    </div>
  </div>
</footer>
