---
// Footer (DESIGN V2): real TCM logo (inverse for dark bg) + tagline, nav columns,
// contact block, copyright. Deep indigo-navy canvas with faint dot texture.
// All copy via ui.ts / site data.
import { t, localizePath, withBase, type Lang } from '../i18n/ui';
import { site, copyrightLine, companyAddress } from '../data/site';
import { services } from '../data/site';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const nav: { key: Parameters<typeof t>[1]; path: string }[] = [
  { key: 'nav.about', path: '/about' },
  { key: 'nav.services', path: '/services' },
  { key: 'nav.projects', path: '/projects' },
  { key: 'nav.clients', path: '/clients' },
  { key: 'nav.contact', path: '/contact' },
];

const logoSrc = withBase('/logo-tcm-inverse.svg');
---

<footer class="relative overflow-hidden bg-canvas-900 text-slate-300">
  <!-- faint dot texture + top accent hairline -->
  <div
    class="pointer-events-none absolute inset-0 bg-dot-dark bg-dot opacity-[0.5]"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent-cyan/40 to-transparent"
    aria-hidden="true"
  >
  </div>

  <div class="container-tcm relative grid gap-10 py-16 sm:grid-cols-2 lg:grid-cols-4">
    <!-- Brand -->
    <div class="lg:col-span-1">
      <!-- inverse logo variant (white fills baked in — <img> SVG can't inherit CSS vars) -->
      <img
        src={logoSrc}
        alt={site.wordmark}
        width="160"
        height="46"
        class="h-10 w-auto"
      />
      <p class="mt-4 max-w-xs text-sm leading-relaxed text-slate-400">
        {t(lang, 'footer.tagline')}
      </p>
      <p class="mt-4 text-sm font-medium text-accent-cyan">{site.slogan}</p>
    </div>

    <!-- Nav -->
    <nav aria-label="Footer navigation">
      <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-white">
        {t(lang, 'footer.nav.title')}
      </h2>
      <ul class="mt-4 space-y-2.5 text-sm">
        {
          nav.map((item) => (
            <li>
              <a
                href={localizePath(item.path, lang)}
                class="text-slate-400 transition hover:text-accent-cyan"
              >
                {t(lang, item.key)}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Services -->
    <nav aria-label="Services">
      <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-white">
        {t(lang, 'footer.services.title')}
      </h2>
      <ul class="mt-4 space-y-2.5 text-sm">
        {
          services.slice(0, 5).map((s) => (
            <li>
              <a
                href={localizePath(`/services/${s.slug}`, lang)}
                class="text-slate-400 transition hover:text-accent-cyan"
              >
                {s.title[lang]}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Contact -->
    <div>
      <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-white">
        {t(lang, 'footer.contact.title')}
      </h2>
      <address class="mt-4 space-y-2.5 text-sm not-italic text-slate-400">
        <p>{companyAddress(lang)}</p>
        <p>
          <a href={`tel:${site.phoneIntl}`} class="transition hover:text-accent-cyan"
            >{site.phone}</a
          >
        </p>
        <p>
          <a href={`mailto:${site.email}`} class="transition hover:text-accent-cyan"
            >{site.email}</a
          >
        </p>
      </address>
    </div>
  </div>

  <div class="relative border-t border-white/10">
    <div
      class="container-tcm flex flex-col items-center justify-between gap-3 py-6 text-sm text-slate-400 sm:flex-row"
    >
      <p>{copyrightLine(lang)} · {t(lang, 'footer.rights')}</p>
      <a
        href={localizePath('/privacy-policy', lang)}
        class="transition hover:text-accent-cyan"
      >
        {t(lang, 'footer.privacy')}
      </a>
    </div>
  </div>
</footer>
