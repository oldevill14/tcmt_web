---
// Service card: blue-gradient rounded card with an inline icon, title and summary.
// Matches the Figma service-card style (rounded-2xl, blue gradient, hover lift).
import { withBase } from '../i18n/ui';

interface Props {
  slug: string;
  title: string;
  summary: string;
  icon?: string;
  href?: string; // override; defaults to localized service detail path passed in
}

const { slug, title, summary, icon = 'network', href } = Astro.props;
const url = href ?? withBase(`/services/${slug}`);

// Minimal inline icon set keyed by `icon`. Avoids an icon-font dependency.
const icons: Record<string, string> = {
  network:
    '<path d="M12 3v4m0 10v4M5.6 5.6l2.8 2.8m7.2 7.2 2.8 2.8M3 12h4m10 0h4M5.6 18.4l2.8-2.8m7.2-7.2 2.8-2.8" /><circle cx="12" cy="12" r="2.5" />',
  server:
    '<rect x="3" y="4" width="18" height="6" rx="1.5" /><rect x="3" y="14" width="18" height="6" rx="1.5" /><path d="M7 7h.01M7 17h.01" />',
  shield:
    '<path d="M12 3 5 6v5c0 4.4 2.9 7.9 7 9 4.1-1.1 7-4.6 7-9V6l-7-3Z" /><path d="m9 12 2 2 4-4" />',
  globe:
    '<circle cx="12" cy="12" r="9" /><path d="M3 12h18M12 3c2.5 2.5 3.8 5.7 3.8 9S14.5 18.5 12 21c-2.5-2.5-3.8-5.7-3.8-9S9.5 5.5 12 3Z" />',
  layers:
    '<path d="m12 3 9 5-9 5-9-5 9-5Z" /><path d="m3 13 9 5 9-5" /><path d="m3 17 9 5 9-5" />',
  monitor:
    '<rect x="3" y="4" width="18" height="12" rx="1.5" /><path d="M8 20h8M12 16v4" />',
  wind:
    '<path d="M3 8h11a2.5 2.5 0 1 0-2.5-2.5M3 12h16a2.5 2.5 0 1 1-2.5 2.5M3 16h9a2 2 0 1 1-2 2" />',
};
const iconPath = icons[icon] ?? icons.network;
---

<a
  href={url}
  class="group relative flex flex-col overflow-hidden rounded-2xl bg-brand-gradient p-6 text-white shadow-card transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover"
>
  <span
    class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-white/15 ring-1 ring-white/25 backdrop-blur"
    aria-hidden="true"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="h-6 w-6"
      set:html={iconPath}
    />
  </span>
  <h3 class="text-lg font-semibold leading-snug">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-white/85">{summary}</p>
  <span
    class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-white/90 transition-transform group-hover:translate-x-1"
    aria-hidden="true"
  >
    →
  </span>
</a>
