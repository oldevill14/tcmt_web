---
// ServiceCard (DESIGN V2 bento) — glass card with pillar accent, icon, hover glow.
// variant: 'hardware' (brand blue accent) | 'software' (cyan accent) | 'default' (neutral)
// accent: true = dark canvas hero card spanning full height
import { withBase } from '../i18n/ui';

interface Props {
  slug: string;
  title: string;
  summary: string;
  icon?: string;
  href?: string;
  pillar?: 'hardware' | 'software';
  accent?: boolean; // true = dark feature card (canvas-900 bg)
}

const {
  slug,
  title,
  summary,
  icon = 'network',
  href,
  pillar = 'hardware',
  accent = false,
} = Astro.props;
const url = href ?? withBase(`/services/${slug}`);

// Inline icon paths (stroke-only, 24×24 viewBox)
const icons: Record<string, string> = {
  network:
    '<path d="M12 3v4m0 10v4M5.6 5.6l2.8 2.8m7.2 7.2 2.8 2.8M3 12h4m10 0h4M5.6 18.4l2.8-2.8m7.2-7.2 2.8-2.8" /><circle cx="12" cy="12" r="2.5" />',
  server:
    '<rect x="3" y="4" width="18" height="6" rx="1.5" /><rect x="3" y="14" width="18" height="6" rx="1.5" /><path d="M7 7h.01M7 17h.01" />',
  shield:
    '<path d="M12 3 5 6v5c0 4.4 2.9 7.9 7 9 4.1-1.1 7-4.6 7-9V6l-7-3Z" /><path d="m9 12 2 2 4-4" />',
  globe:
    '<circle cx="12" cy="12" r="9" /><path d="M3 12h18M12 3c2.5 2.5 3.8 5.7 3.8 9S14.5 18.5 12 21c-2.5-2.5-3.8-5.7-3.8-9S9.5 5.5 12 3Z" />',
  layers:
    '<path d="m12 3 9 5-9 5-9-5 9-5Z" /><path d="m3 13 9 5 9-5" /><path d="m3 17 9 5 9-5" />',
  monitor:
    '<rect x="3" y="4" width="18" height="12" rx="1.5" /><path d="M8 20h8M12 16v4" />',
  wind:
    '<path d="M3 8h11a2.5 2.5 0 1 0-2.5-2.5M3 12h16a2.5 2.5 0 1 1-2.5 2.5M3 16h9a2 2 0 1 1-2 2" />',
  code:
    '<path d="m8 8-4 4 4 4M16 8l4 4-4 4M14 4l-4 16" />',
};
const iconPath = icons[icon] ?? icons.network;

// Accent colours per pillar
const iconBg = accent
  ? 'bg-accent-gradient-soft text-white shadow-glow-cyan'
  : pillar === 'software'
    ? 'bg-accent-cyan/10 text-accent-cyan'
    : 'bg-brand-500/10 text-brand-600';

const arrowColor = accent
  ? 'text-accent-cyan'
  : pillar === 'software'
    ? 'text-accent-cyan'
    : 'text-brand-500';
---

<a
  href={url}
  class:list={[
    'group relative flex flex-col overflow-hidden rounded-2xl p-6 transition-all duration-300',
    'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-cyan focus-visible:ring-offset-2',
    accent
      ? 'bg-canvas-900 text-white hover-lift gradient-border'
      : 'card-surface hover-lift',
  ]}
>
  {/* Glow orb on dark accent cards */}
  {accent && (
    <div
      class="pointer-events-none absolute -right-8 -top-8 h-40 w-40 rounded-full bg-accent-gradient opacity-20 blur-2xl transition-opacity duration-500 group-hover:opacity-35"
      aria-hidden="true"
    />
  )}
  {/* Faint circuit grid texture on dark cards */}
  {accent && (
    <div
      class="pointer-events-none absolute inset-0 bg-grid-dark bg-grid opacity-[0.35]"
      aria-hidden="true"
    />
  )}

  {/* Icon */}
  <span
    class:list={[
      'relative mb-5 inline-flex h-12 w-12 items-center justify-center rounded-2xl',
      iconBg,
    ]}
    aria-hidden="true"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="relative h-6 w-6"
      set:html={iconPath}
    />
  </span>

  {/* Content */}
  <h3
    class:list={[
      'relative text-lg font-semibold leading-snug',
      accent ? 'text-white' : 'text-ink',
    ]}
  >
    {title}
  </h3>
  <p
    class:list={[
      'relative mt-2 flex-1 text-sm leading-relaxed',
      accent ? 'text-slate-300' : 'text-muted',
    ]}
  >
    {summary}
  </p>

  {/* Arrow CTA */}
  <span
    class:list={[
      'relative mt-5 inline-flex items-center gap-1.5 text-sm font-semibold transition-transform duration-200 group-hover:translate-x-1',
      arrowColor,
    ]}
    aria-hidden="true"
  >
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
      <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>
</a>
