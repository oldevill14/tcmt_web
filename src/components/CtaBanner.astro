---
// Full-width solid TCM-blue CTA banner pointing to /contact.
// DESIGN V4 (TANGERINE-STYLE) — solid blue band, white rounded-full pill CTAs.
// No aurora / glow / glass. Mirrors Tangerine's orange "Contact Us" band but in TCM blue.
import { t, localizePath, type Lang } from '../i18n/ui';
import Button from './Button.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<section class="section">
  <div class="container-tcm">
    <div
      class="relative overflow-hidden rounded-3xl text-white"
      style="background: linear-gradient(135deg, #0a3580 0%, #0b3d91 45%, #1565d8 100%);"
      data-reveal
    >
      <!-- Subtle flat light-scatter — two soft white radials, no animation, no blur overload -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-3xl" aria-hidden="true">
        <div
          class="absolute -top-[40%] left-[-5%] h-[90%] w-[50%] rounded-full opacity-[0.07]"
          style="background: radial-gradient(circle, #ffffff, transparent 70%);"
        ></div>
        <div
          class="absolute bottom-[-40%] right-[-5%] h-[90%] w-[45%] rounded-full opacity-[0.06]"
          style="background: radial-gradient(circle, #a9d1ff, transparent 70%);"
        ></div>
      </div>

      <!-- Content -->
      <div class="relative px-8 py-14 sm:px-14 sm:py-20">
        <div class="mx-auto max-w-2xl text-center">
          <!-- Eyebrow chip -->
          <span class="mb-5 inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-white ring-1 ring-inset ring-white/25">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-200" aria-hidden="true"></span>
            {lang === 'th' ? 'ปรึกษาฟรี' : 'Free consultation'}
          </span>

          <h2 class="text-2xl font-extrabold text-white sm:text-3xl lg:text-4xl" style="text-wrap: balance;">
            {t(lang, 'home.cta.title')}
          </h2>

          <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-white">
            {t(lang, 'home.cta.subtitle')}
          </p>

          <!-- Contact Sales = PRIMARY (white pill on blue), View Services = secondary (outline) -->
          <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
            <Button href={localizePath('/contact', lang)} variant="white" size="lg">
              {t(lang, 'btn.contactSales')}
            </Button>
            <Button href={localizePath('/services', lang)} variant="glass" size="lg">
              {t(lang, 'btn.viewServices')}
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
