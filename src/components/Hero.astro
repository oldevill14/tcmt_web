---
// DESIGN V4 (TANGERINE-STYLE) hero: LIGHT & warm. Left = blue eyebrow kicker +
// bold navy headline (hardware + software positioning) + subtext + dual pill CTA
// (primary blue "Contact Sales"). Right = a clean FLAT SVG illustration.
// No dark background, no aurora, no glass/glow. Soft cream wash + hairline grid.
import { t, localizePath, withBase, type Lang } from '../i18n/ui';
import Button from './Button.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Two capability pillars rendered as flat chips beneath the CTA.
type K = Parameters<typeof t>[1];
const pillars = [
  {
    title: t(lang, 'home.hero.pillar.hardware' as K),
    icon: 'server',
  },
  {
    title: t(lang, 'home.hero.pillar.software' as K),
    icon: 'code',
  },
];
const pillarIcons: Record<string, string> = {
  server:
    '<rect x="3" y="4" width="18" height="6" rx="1.5" /><rect x="3" y="14" width="18" height="6" rx="1.5" /><path d="M7 7h.01M7 17h.01" />',
  code: '<path d="m8 8-4 4 4 4M16 8l4 4-4 4M14 4l-4 16" />',
};

const heroIllo = withBase('/illustrations/hero-it-team.svg');
---

<section class="relative overflow-hidden bg-bg-cream">
  <!-- faint hairline grid + a soft blue wash blob (flat, no animation) -->
  <div class="pointer-events-none absolute inset-0 bg-grid-light bg-grid opacity-60" aria-hidden="true"></div>
  <div
    class="pointer-events-none absolute -right-24 -top-24 h-[34rem] w-[34rem] rounded-full bg-brand-50 opacity-70 blur-2xl"
    aria-hidden="true"
  >
  </div>

  <div class="container-tcm relative grid items-center gap-10 py-16 sm:py-20 lg:grid-cols-12 lg:gap-12 lg:py-28">
    <!-- copy -->
    <div class="lg:col-span-6">
      <p class="eyebrow animate-fade-up">
        <span class="inline-block h-1 w-5 rounded-full bg-brand-600" aria-hidden="true"></span>
        {t(lang, 'home.hero.eyebrow')}
      </p>

      <h1
        class="mt-5 text-display-sm font-extrabold text-ink animate-fade-up [animation-delay:80ms] sm:text-display lg:text-display-lg"
      >
        <span class="block">{t(lang, 'home.hero.line1')}</span>
        <span class="text-brand-600">{t(lang, 'home.hero.line2')}</span>
      </h1>

      <p
        class="mt-6 max-w-xl text-lg leading-relaxed text-muted animate-fade-up [animation-delay:160ms]"
      >
        {t(lang, 'home.hero.subtitle')}
      </p>

      <div class="mt-8 flex flex-wrap gap-3 animate-fade-up [animation-delay:240ms]">
        <Button href={localizePath('/contact', lang)} variant="primary" size="lg">
          {t(lang, 'btn.contactSales')}
        </Button>
        <Button href={localizePath('/services', lang)} variant="secondary" size="lg">
          {t(lang, 'home.hero.ctaSecondary')}
        </Button>
      </div>

      <!-- two-discipline chips -->
      <div class="mt-8 flex flex-wrap gap-2.5 animate-fade-up [animation-delay:320ms]">
        {
          pillars.map((p) => (
            <span class="inline-flex items-center gap-2 rounded-full border border-line bg-white px-4 py-2 text-sm font-semibold text-ink shadow-sm">
              <span class="grid h-6 w-6 place-items-center rounded-full bg-brand-50 text-brand-600" aria-hidden="true">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.9"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-3.5 w-3.5"
                  set:html={pillarIcons[p.icon]}
                />
              </span>
              {p.title}
            </span>
          ))
        }
      </div>
    </div>

    <!-- flat illustration -->
    <div class="lg:col-span-6">
      <div class="relative mx-auto max-w-lg animate-scale-in [animation-delay:160ms]">
        <img
          src={heroIllo}
          alt={t(lang, 'home.hero.motif.label')}
          width="560"
          height="460"
          class="h-auto w-full"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
