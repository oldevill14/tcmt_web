---
// ServicesSections (DESIGN V4 Tangerine-style) — services overview page body.
// LIGHT / warm / flat: white page hero, cream section bg, 3-col flat card grid.
// Two pillars (Hardware & Infrastructure | Software & Web) on alternating light
// surfaces — NO dark canvas, NO glow, NO glass, NO aurora.
import { t, localizePath, type Lang } from '../i18n/ui';
import { services } from '../data/site';
import ServiceCard from './ServiceCard.astro';
import CtaBanner from './CtaBanner.astro';
import Button from './Button.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Split into two pillars
const hardwareServices = services.filter((s) => s.slug !== 'software-development');
const softwareServices = services.filter((s) => s.slug === 'software-development');

// Pillar label strings
const pillarHardware =
  lang === 'th' ? 'ฮาร์ดแวร์และโครงสร้างพื้นฐาน' : 'Hardware & Infrastructure';
const pillarSoftware =
  lang === 'th' ? 'ซอฟต์แวร์และการพัฒนาเว็บ' : 'Software & Web Development';
const pillarHardwareDesc =
  lang === 'th'
    ? 'ระบบเครือข่าย ดาต้าเซ็นเตอร์ ความปลอดภัย และโครงสร้างพื้นฐานไอทีครบวงจร'
    : 'Networking, data center, security and end-to-end IT infrastructure systems.';
const pillarSoftwareDesc =
  lang === 'th'
    ? 'ซอฟต์แวร์เฉพาะองค์กร เว็บแอปพลิเคชัน และระบบบูรณาการ'
    : 'Custom software, web applications and system integration.';
const eyebrowLabel = lang === 'th' ? 'สิ่งที่เราทำ' : 'What we do';
const contactLabel = lang === 'th' ? 'ปรึกษาโครงการ' : 'Discuss your project';
const integratedLabel =
  lang === 'th' ? 'ซอฟต์แวร์ + โครงสร้างพื้นฐาน' : 'Software + Infrastructure';
const integratedBody =
  lang === 'th'
    ? 'TCM เชี่ยวชาญทั้งสองด้าน จึงส่งมอบโซลูชัน end-to-end ที่เชื่อมต่อกันได้สมบูรณ์ — ไม่ต้องประสานงานหลายเจ้า'
    : 'TCM masters both layers, delivering fully connected end-to-end solutions — no multi-vendor coordination overhead.';
---

<!-- Page hero — LIGHT cream bg, blue eyebrow, navy headline -->
<section class="bg-bg-soft pb-20 pt-24 sm:pt-32">
  <div class="container-tcm text-center">
    <p class="eyebrow mb-4 justify-center" data-reveal>
      <span class="inline-block h-1 w-5 rounded-full bg-brand-600" aria-hidden="true"></span>
      {eyebrowLabel}
    </p>
    <h1
      class="text-display-sm font-bold tracking-tight text-ink sm:text-display"
      data-reveal
      data-reveal-delay="60"
    >
      {t(lang, 'services.title')}
    </h1>
    <p
      class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-muted"
      data-reveal
      data-reveal-delay="120"
    >
      {t(lang, 'services.subtitle')}
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3" data-reveal data-reveal-delay="180">
      <Button href={localizePath('/contact', lang)} variant="primary" size="md">
        {contactLabel}
      </Button>
    </div>
  </div>
</section>

<!-- Pillar 1: Hardware & Infrastructure — white bg -->
<section class="section bg-white">
  <div class="container-tcm">

    <!-- Pillar header -->
    <div class="mb-10" data-reveal>
      <div class="flex items-center gap-4">
        <span
          class="inline-flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-brand-50 text-brand-600"
          aria-hidden="true"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
          >
            <rect x="3" y="4" width="18" height="6" rx="1.5" />
            <rect x="3" y="14" width="18" height="6" rx="1.5" />
            <path d="M7 7h.01M7 17h.01" />
          </svg>
        </span>
        <div>
          <h2 class="text-xl font-bold text-ink">{pillarHardware}</h2>
          <p class="mt-0.5 text-sm text-muted">{pillarHardwareDesc}</p>
        </div>
      </div>
      <!-- Hairline accent below header -->
      <div class="mt-4 h-px bg-gradient-to-r from-brand-200 via-brand-100 to-transparent"></div>
    </div>

    <!-- 3-col flat card grid -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        hardwareServices.map((s, i) => (
          <div data-reveal data-reveal-delay={i * 70}>
            <ServiceCard
              slug={s.slug}
              title={s.title[lang]}
              summary={s.summary[lang]}
              icon={s.icon}
              href={localizePath(`/services/${s.slug}`, lang)}
              pillar="hardware"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- Hairline section divider -->
<div class="h-px bg-line" aria-hidden="true"></div>

<!-- Pillar 2: Software & Web Development — warm cream bg (light, no dark canvas) -->
<section class="section bg-bg-cream">
  <div class="container-tcm">

    <!-- Pillar header -->
    <div class="mb-10" data-reveal>
      <div class="flex items-center gap-4">
        <span
          class="inline-flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-brand-50 text-brand-600"
          aria-hidden="true"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
          >
            <path d="m8 8-4 4 4 4M16 8l4 4-4 4M14 4l-4 16" />
          </svg>
        </span>
        <div>
          <h2 class="text-xl font-bold text-ink">{pillarSoftware}</h2>
          <p class="mt-0.5 text-sm text-muted">{pillarSoftwareDesc}</p>
        </div>
      </div>
      <div class="mt-4 h-px bg-gradient-to-r from-brand-200 via-brand-100 to-transparent"></div>
    </div>

    <!-- Software + integration two-column layout -->
    <div class="grid gap-5 lg:grid-cols-5">
      <!-- Main software card — spans 3 cols -->
      <div class="lg:col-span-3" data-reveal>
        {
          softwareServices.map((s) => (
            <ServiceCard
              slug={s.slug}
              title={s.title[lang]}
              summary={s.summary[lang]}
              icon={s.icon}
              href={localizePath(`/services/${s.slug}`, lang)}
              pillar="software"
            />
          ))
        }
      </div>

      <!-- Integration motif card — spans 2 cols — flat light card -->
      <div
        class="flex flex-col justify-between rounded-2xl border border-line bg-white p-6 shadow-card lg:col-span-2"
        data-reveal
        data-reveal-delay="90"
      >
        <!-- Integration icon row -->
        <div class="flex items-center gap-3" aria-hidden="true">
          {
            (
              [
                { key: 'server', primary: false },
                { key: 'arrows', primary: true },
                { key: 'code', primary: false },
              ] as { key: string; primary: boolean }[]
            ).map(({ key, primary }) => (
              <span
                class:list={[
                  'inline-flex h-9 w-9 items-center justify-center rounded-xl',
                  primary ? 'bg-brand-50 text-brand-600' : 'bg-bg-soft text-muted',
                ]}
              >
                {key === 'server' && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-4 w-4"
                  >
                    <rect x="3" y="4" width="18" height="6" rx="1.5" />
                    <rect x="3" y="14" width="18" height="6" rx="1.5" />
                    <path d="M7 7h.01M7 17h.01" />
                  </svg>
                )}
                {key === 'arrows' && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-4 w-4"
                  >
                    <path d="M7 16V4m0 0L4 7m3-3 3 3M17 8v12m0 0 3-3m-3 3-3-3" />
                  </svg>
                )}
                {key === 'code' && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-4 w-4"
                  >
                    <path d="m8 8-4 4 4 4M16 8l4 4-4 4M14 4l-4 16" />
                  </svg>
                )}
              </span>
            ))
          }
        </div>

        <div class="mt-5">
          <h3 class="text-base font-semibold text-ink">{integratedLabel}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">
            {integratedBody}
          </p>
        </div>

        <div class="mt-6">
          <Button href={localizePath('/contact', lang)} variant="secondary" size="sm">
            {contactLabel}
          </Button>
        </div>
      </div>
    </div>

  </div>
</section>

<CtaBanner lang={lang} />
