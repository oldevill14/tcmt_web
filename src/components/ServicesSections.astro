---
// ServicesSections (DESIGN V2 bento) — services overview page body.
// Groups services into two pillars: Hardware & Infrastructure | Software & Web.
// Renders an asymmetric bento grid with dark feature card, glass surface cards,
// gradient-border on the software pillar accent, and scroll-reveal per item.
import { t, localizePath, type Lang } from '../i18n/ui';
import { services } from '../data/site';
import ServiceCard from './ServiceCard.astro';
import CtaBanner from './CtaBanner.astro';
import Button from './Button.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Split into two pillars. The software-development slug is the software pillar;
// everything else belongs to hardware / infrastructure.
const hardwareServices = services.filter((s) => s.slug !== 'software-development');
const softwareServices = services.filter((s) => s.slug === 'software-development');

// Pillar label strings (inlined — no ui.ts edit allowed)
const pillarHardware = lang === 'th' ? 'ฮาร์ดแวร์และโครงสร้างพื้นฐาน' : 'Hardware & Infrastructure';
const pillarSoftware = lang === 'th' ? 'ซอฟต์แวร์และการพัฒนาเว็บ' : 'Software & Web Development';
const pillarHardwareDesc =
  lang === 'th'
    ? 'ระบบเครือข่าย ดาต้าเซ็นเตอร์ ความปลอดภัย และโครงสร้างพื้นฐานไอทีครบวงจร'
    : 'Networking, data center, security and end-to-end IT infrastructure systems.';
const pillarSoftwareDesc =
  lang === 'th'
    ? 'ซอฟต์แวร์เฉพาะองค์กร เว็บแอปพลิเคชัน และระบบบูรณาการ'
    : 'Custom software, web applications and system integration.';
const eyebrowLabel = lang === 'th' ? 'สิ่งที่เราทำ' : 'What we do';
const contactLabel = lang === 'th' ? 'ปรึกษาโครงการ' : 'Discuss your project';
---

<!-- Page hero — dark canvas with grid texture -->
<section class="relative bg-canvas-950 pb-20 pt-24 sm:pt-32">
  <div
    class="pointer-events-none absolute inset-0 bg-grid-dark bg-grid opacity-[0.4]"
    aria-hidden="true"
  ></div>
  <!-- Accent gradient glow top-right -->
  <div
    class="pointer-events-none absolute -right-32 -top-16 h-[480px] w-[480px] rounded-full bg-accent-gradient opacity-[0.12] blur-3xl"
    aria-hidden="true"
  ></div>
  <!-- Hairline separator at bottom -->
  <div
    class="pointer-events-none absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent-cyan/30 to-transparent"
    aria-hidden="true"
  ></div>

  <div class="container-tcm relative text-center">
    <p class="eyebrow-light mb-4 justify-center">
      <span class="inline-block h-1 w-5 rounded-full bg-accent-gradient-soft" aria-hidden="true"></span>
      {eyebrowLabel}
    </p>
    <h1 class="gradient-text-light text-display-sm font-bold tracking-tight sm:text-display">
      {t(lang, 'services.title')}
    </h1>
    <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-slate-300">
      {t(lang, 'services.subtitle')}
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <Button href={localizePath('/contact', lang)} variant="gradient" size="md">
        {contactLabel}
      </Button>
    </div>
  </div>
</section>

<!-- Pillar 1: Hardware & Infrastructure -->
<section class="section">
  <div class="container-tcm">

    <!-- Pillar header -->
    <div class="mb-10" data-reveal>
      <div class="flex items-center gap-4">
        <span
          class="inline-flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-brand-500/10 text-brand-600"
          aria-hidden="true"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
            <rect x="3" y="4" width="18" height="6" rx="1.5" /><rect x="3" y="14" width="18" height="6" rx="1.5" /><path d="M7 7h.01M7 17h.01" />
          </svg>
        </span>
        <div>
          <h2 class="text-xl font-bold text-ink">{pillarHardware}</h2>
          <p class="mt-0.5 text-sm text-muted">{pillarHardwareDesc}</p>
        </div>
      </div>
      <div class="mt-4 h-px bg-gradient-to-r from-brand-500/40 via-brand-300/20 to-transparent"></div>
    </div>

    <!-- Bento grid: first card is accent (dark, large), rest are glass surface cards -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        hardwareServices.map((s, i) => (
          <div
            class:list={[
              i === 0 ? 'sm:col-span-2 lg:col-span-1' : '',
            ]}
            data-reveal
            data-reveal-delay={i * 70}
          >
            <ServiceCard
              slug={s.slug}
              title={s.title[lang]}
              summary={s.summary[lang]}
              icon={s.icon}
              href={localizePath(`/services/${s.slug}`, lang)}
              pillar="hardware"
              accent={i === 0}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- Divider wave -->
<div class="relative h-px" aria-hidden="true">
  <div class="absolute inset-0 bg-gradient-to-r from-transparent via-accent-cyan/25 to-transparent"></div>
</div>

<!-- Pillar 2: Software & Web Development (dark canvas section) -->
<section class="relative section bg-canvas-950 text-white">
  <div
    class="pointer-events-none absolute inset-0 bg-dot-dark bg-dot opacity-[0.35]"
    aria-hidden="true"
  ></div>
  <!-- Glow accent top-left -->
  <div
    class="pointer-events-none absolute -left-24 top-0 h-80 w-80 rounded-full bg-accent-gradient opacity-[0.10] blur-3xl"
    aria-hidden="true"
  ></div>

  <div class="container-tcm relative">

    <!-- Pillar header -->
    <div class="mb-10" data-reveal>
      <div class="flex items-center gap-4">
        <span
          class="inline-flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-accent-cyan/10 text-accent-cyan"
          aria-hidden="true"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
            <path d="m8 8-4 4 4 4M16 8l4 4-4 4M14 4l-4 16" />
          </svg>
        </span>
        <div>
          <h2 class="text-xl font-bold text-white">{pillarSoftware}</h2>
          <p class="mt-0.5 text-sm text-slate-400">{pillarSoftwareDesc}</p>
        </div>
      </div>
      <div class="mt-4 h-px bg-gradient-to-r from-accent-cyan/40 via-accent-cyan/15 to-transparent"></div>
    </div>

    <!-- Software bento: full-width feature card + integration callout -->
    <div class="grid gap-5 lg:grid-cols-5">
      <!-- Main software card — spans 3 cols, dark accent style -->
      <div class="lg:col-span-3" data-reveal>
        {
          softwareServices.map((s) => (
            <ServiceCard
              slug={s.slug}
              title={s.title[lang]}
              summary={s.summary[lang]}
              icon={s.icon}
              href={localizePath(`/services/${s.slug}`, lang)}
              pillar="software"
              accent
            />
          ))
        }
      </div>

      <!-- Integration motif card — spans 2 cols -->
      <div
        class="glass-dark gradient-border relative flex flex-col justify-between overflow-hidden rounded-2xl p-6 lg:col-span-2"
        data-reveal
        data-reveal-delay="90"
      >
        <div
          class="pointer-events-none absolute -right-6 -top-6 h-32 w-32 rounded-full bg-accent-gradient opacity-15 blur-2xl"
          aria-hidden="true"
        ></div>
        <!-- Integration icon row -->
        <div class="relative flex items-center gap-3" aria-hidden="true">
          {['server', 'arrows', 'code'].map((k, idx) => (
            <span class:list={[
              'inline-flex h-9 w-9 items-center justify-center rounded-xl',
              idx === 1 ? 'bg-accent-cyan/15 text-accent-cyan' : 'bg-white/10 text-slate-400'
            ]}>
              {k === 'server' && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                  <rect x="3" y="4" width="18" height="6" rx="1.5" /><rect x="3" y="14" width="18" height="6" rx="1.5" /><path d="M7 7h.01M7 17h.01" />
                </svg>
              )}
              {k === 'arrows' && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                  <path d="M7 16V4m0 0L4 7m3-3 3 3M17 8v12m0 0 3-3m-3 3-3-3" />
                </svg>
              )}
              {k === 'code' && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                  <path d="m8 8-4 4 4 4M16 8l4 4-4 4M14 4l-4 16" />
                </svg>
              )}
            </span>
          ))}
        </div>

        <div class="relative mt-5">
          <h3 class="text-base font-semibold text-white">
            {lang === 'th' ? 'ซอฟต์แวร์ + โครงสร้างพื้นฐาน' : 'Software + Infrastructure'}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">
            {lang === 'th'
              ? 'TCM เชี่ยวชาญทั้งสองด้าน จึงส่งมอบโซลูชัน end-to-end ที่เชื่อมต่อกันได้สมบูรณ์ — ไม่ต้องประสานงานหลายเจ้า'
              : 'TCM masters both layers, delivering fully connected end-to-end solutions — no multi-vendor coordination overhead.'}
          </p>
        </div>

        <div class="relative mt-6">
          <Button
            href={localizePath('/contact', lang)}
            variant="glass"
            size="sm"
          >
            {lang === 'th' ? 'ปรึกษาโครงการ' : 'Discuss your project'}
          </Button>
        </div>
      </div>
    </div>

  </div>
</section>

<CtaBanner lang={lang} />
