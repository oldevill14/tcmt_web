---
// Composes the full homepage body (DESIGN V4 — TANGERINE-STYLE light flow), so
// the th + en index pages stay thin. Distinct eyebrow kickers on every
// SectionTitle. Light/flat throughout: alternating white + cream/soft-blue
// section backgrounds, flat cards, blue accent, NO dark panels (except the final
// blue CTA band, which CtaBanner owns).
//
// Flow: Hero → Trust band → Clients (trust) → Services 3-col → Solutions by Sector
//       (pill tabs) → Capabilities → Stats → Partners → blue CTA band.
import { t, localizePath, withBase, type Lang } from '../i18n/ui';
import { services, clients, partners } from '../data/site';
import Hero from './Hero.astro';
import SectionTitle from './SectionTitle.astro';
import ServiceCard from './ServiceCard.astro';
import StatsStrip from './StatsStrip.astro';
import LogoGrid from './LogoGrid.astro';
import CtaBanner from './CtaBanner.astro';
import Button from './Button.astro';
import TrustBand from './TrustBand.astro';
import SolutionsBySector from './SolutionsBySector.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const govClients = clients
  .filter((c) => c.sector === 'gov')
  .map((c) => ({ name: c.name[lang], logo: c.logo, url: c.url }));

// Partner logos (real SVGs in /public/logos). Build a marquee-friendly list.
const partnerItems = partners.map((p) => ({
  name: p.name,
  logo: withBase(`/logos/${p.name.toLowerCase()}.svg`),
  url: p.url,
}));
// duplicate the list so the infinite marquee loops seamlessly
const marqueeItems = [...partnerItems, ...partnerItems];

// Capability cards (hardware / software / support) — flat light spot-illustration cards.
type K = Parameters<typeof t>[1];
const caps = [
  {
    title: t(lang, 'home.capabilities.hardware.title' as K),
    body: t(lang, 'home.capabilities.hardware.body' as K),
    illo: 'spot-network',
  },
  {
    title: t(lang, 'home.capabilities.software.title' as K),
    body: t(lang, 'home.capabilities.software.body' as K),
    illo: 'spot-software',
  },
  {
    title: t(lang, 'home.capabilities.support.title' as K),
    body: t(lang, 'home.capabilities.support.body' as K),
    illo: 'spot-dashboard',
  },
];
---

<Hero lang={lang} />

<!-- T1 — Trust & Authority credentials band (seats under hero, light surface) -->
<section class="section bg-white pb-10 pt-14 sm:pb-12 sm:pt-16">
  <div class="container-tcm">
    <TrustBand lang={lang} />
  </div>
</section>

<!-- Clients strip (trust) -->
<section class="section bg-bg-soft">
  <div class="container-tcm">
    <div data-reveal>
      <SectionTitle
        eyebrow={t(lang, 'home.clients.eyebrow')}
        title={t(lang, 'home.clients.title')}
        subtitle={t(lang, 'home.clients.subtitle')}
      />
    </div>
    <div class="mt-12" data-reveal>
      <LogoGrid items={govClients} columns={3} />
    </div>
  </div>
</section>

<!-- What we do — services 3-col grid -->
<section class="section bg-white">
  <div class="container-tcm">
    <div data-reveal>
      <SectionTitle
        eyebrow={t(lang, 'home.services.eyebrow')}
        title={t(lang, 'home.services.title')}
        subtitle={t(lang, 'home.services.subtitle')}
      />
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s, i) => (
          <div data-reveal data-reveal-delay={(i % 3) * 80}>
            <ServiceCard
              slug={s.slug}
              title={s.title[lang]}
              summary={s.summary[lang]}
              icon={s.icon}
              href={localizePath(`/services/${s.slug}`, lang)}
            />
          </div>
        ))
      }
    </div>
    <div class="mt-12 text-center" data-reveal>
      <Button href={localizePath('/services', lang)} variant="secondary" size="md">
        {t(lang, 'btn.viewServices')}
      </Button>
    </div>
  </div>
</section>

<!-- T2 — Solutions by Sector (Enterprise Gateway: gov / education / enterprise) -->
<SolutionsBySector lang={lang} />

<!-- Capabilities: hardware AND software (positioning) — flat illustrated cards -->
<section class="section bg-white">
  <div class="container-tcm">
    <div data-reveal>
      <SectionTitle
        eyebrow={t(lang, 'home.capabilities.eyebrow')}
        title={t(lang, 'home.capabilities.title')}
        subtitle={t(lang, 'home.capabilities.subtitle')}
        gradient
      />
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        caps.map((c, i) => (
          <div
            class="group flex flex-col items-start rounded-2xl border border-line bg-white p-7 shadow-card hover-lift"
            data-reveal
            data-reveal-delay={i * 90}
          >
            <img
              src={withBase(`/illustrations/${c.illo}.svg`)}
              alt=""
              aria-hidden="true"
              width="120"
              height="120"
              loading="lazy"
              decoding="async"
              class="mb-5 h-24 w-24"
            />
            <h3 class="text-lg font-bold text-ink">{c.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{c.body}</p>
          </div>
        ))
      }
    </div>
    <div class="mt-12 text-center" data-reveal>
      <Button href={localizePath('/services', lang)} variant="primary" size="md">
        {t(lang, 'btn.viewServices')}
      </Button>
    </div>
  </div>
</section>

<!-- Stats — proof, on a soft cream band -->
<section class="section bg-bg-cream">
  <div class="container-tcm">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <p class="eyebrow justify-center">
        <span class="inline-block h-1 w-5 rounded-full bg-brand-600" aria-hidden="true"></span>
        {t(lang, 'home.stats.eyebrow')}
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink sm:text-4xl">
        {t(lang, 'home.stats.title')}
      </h2>
    </div>
    <div class="mt-12" data-reveal>
      <StatsStrip lang={lang} />
    </div>
  </div>
</section>

<!-- Authorized partners marquee (real logos, grayscale -> color on hover) -->
<section class="section bg-white">
  <div class="container-tcm">
    <div data-reveal>
      <SectionTitle
        eyebrow={t(lang, 'home.partners.eyebrow')}
        title={t(lang, 'home.partners.title')}
        subtitle={t(lang, 'home.partners.subtitle')}
      />
    </div>
  </div>
  <div class="mt-12 marquee" data-reveal>
    <ul class="marquee__track gap-4 sm:gap-6" aria-label={t(lang, 'home.partners.title')}>
      {
        marqueeItems.map((p, i) => (
          <li class="shrink-0" aria-hidden={i >= partnerItems.length ? 'true' : undefined}>
            <a
              href={p.url}
              target="_blank"
              rel="noopener noreferrer"
              title={p.name}
              tabindex={i >= partnerItems.length ? -1 : undefined}
              class="group flex h-24 w-44 items-center justify-center rounded-2xl border border-line bg-white px-6 transition hover:shadow-card"
            >
              <img
                src={p.logo}
                alt={p.name}
                loading="lazy"
                decoding="async"
                width="120"
                height="40"
                class="max-h-9 w-auto object-contain opacity-60 grayscale transition duration-300 group-hover:opacity-100 group-hover:grayscale-0"
              />
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<!-- Blue CTA band -->
<CtaBanner lang={lang} />
