---
// Button / link component. Renders an <a> when `href` is given, else a <button>.
// DESIGN V4 (TANGERINE-STYLE): rounded-full PILL buttons, light & flat.
// Variants:
//   primary   — solid TCM-blue pill (the main CTA)
//   gradient  — alias of primary (kept: legacy markup passes variant="gradient")
//   secondary — white pill, hairline border, navy text (outline)
//   ghost     — text-only blue, subtle hover wash
//   white     — white pill (for use ON the blue CTA band)
//   glass     — translucent-white pill (for use ON dark/navy surfaces)
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'white' | 'gradient' | 'glass';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  class: className = '',
  ...rest
} = Astro.props;

const base =
  'group/btn relative inline-flex cursor-pointer items-center justify-center gap-2 rounded-full font-semibold transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 disabled:opacity-60 disabled:pointer-events-none';

const variants: Record<string, string> = {
  // solid blue pill — the primary conversion
  primary:
    'bg-brand-600 text-white shadow-pill hover:bg-brand-700 hover:-translate-y-0.5',
  // legacy alias — same solid blue pill (no more cyan mesh)
  gradient:
    'bg-brand-600 text-white shadow-pill hover:bg-brand-700 hover:-translate-y-0.5',
  // white outline pill
  secondary:
    'bg-white text-ink ring-1 ring-inset ring-line shadow-sm hover:ring-brand-300 hover:text-brand-700',
  ghost: 'text-brand-700 hover:bg-brand-50',
  // white pill for the blue CTA band
  white: 'bg-white text-brand-700 shadow-pill hover:bg-brand-50 hover:-translate-y-0.5',
  // translucent-white pill for dark/navy surfaces
  glass:
    'bg-white/10 text-white ring-1 ring-inset ring-white/30 backdrop-blur-sm hover:bg-white/20 hover:ring-white/50',
};

const sizes: Record<string, string> = {
  // min-height keeps touch targets comfortable (44px+) per a11y brief
  sm: 'min-h-[44px] px-4 py-2 text-sm',
  md: 'min-h-[44px] px-5 py-2.5 text-sm',
  lg: 'min-h-[52px] px-7 py-3 text-base',
};

const cls = [base, variants[variant] ?? variants.primary, sizes[size], className].join(' ');
---

{
  href ? (
    <a href={href} class={cls} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={cls} {...rest}>
      <slot />
    </button>
  )
}
