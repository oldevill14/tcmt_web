---
// Base page layout. Sets <html lang>, renders <Seo/>, Header, slot, Footer.
// Every page should use this and pass at least { lang, title, description }.
import '../styles/global.css';
import { getLang, t, withBase, type Lang } from '../i18n/ui';
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** Override the auto-detected lang. Defaults to deriving it from the URL. */
  lang?: Lang;
  /** Path without base/locale prefix (e.g. '/about') for SEO alternates. */
  path?: string;
  image?: string;
  noindex?: boolean;
  /** Make the language toggle link to the other locale's home (used on 404 — no localized sibling). */
  langSwitchHome?: boolean;
}

const {
  title,
  description,
  path = '/',
  image,
  noindex = false,
  lang: langProp,
  langSwitchHome = false,
} = Astro.props;

const lang: Lang = langProp ?? getLang(Astro.url);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" type="image/png" sizes="192x192" href={withBase('/icon-192.png')} />
    <link rel="apple-touch-icon" sizes="180x180" href={withBase('/apple-touch-icon.png')} />
    <link rel="manifest" href={withBase('/site.webmanifest')} />
    <meta name="theme-color" content="#0b3d91" />
    <meta name="application-name" content="TCM Technology" />
    <meta name="apple-mobile-web-app-title" content="TCM Technology" />
    <meta name="msapplication-TileColor" content="#0b3d91" />
    <Seo
      lang={lang}
      title={title}
      description={description}
      path={path}
      image={image}
      noindex={noindex}
    />
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-brand-700 focus:px-4 focus:py-2 focus:text-white"
    >
      {t(lang, 'a11y.skipToContent')}
    </a>
    <Header lang={lang} langSwitchHome={langSwitchHome} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- Scroll-reveal activator (progressive enhancement, site-wide).
         Reveals [data-reveal] elements as they enter the viewport.
         No-op / fully visible if JS disabled or reduced-motion is preferred. -->
    <script is:inline>
      (() => {
        const els = document.querySelectorAll('[data-reveal]');
        if (!els.length) return;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const el = entry.target;
              const delay = el.getAttribute('data-reveal-delay');
              if (delay) el.style.transitionDelay = delay + 'ms';
              el.classList.add('is-visible');
              io.unobserve(el);
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.08 }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
